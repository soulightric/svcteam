generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   @default("ADMIN") // SUPER_ADMIN (admin biasa/penerus) atau ADMIN (admin kategori)
  kategori  String?  // diisi untuk admin kategori: akademik, perpustakaan, dst. null untuk SUPER_ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Mahasiswa {
  id        String     @id @default(cuid())
  nim       String     @unique
  nama      String
  password  String
  createdAt DateTime   @default(now())
  feedbacks Feedback[]
}

model Feedback {
  id          String     @id @default(cuid())
  kategori    String
  judul       String
  deskripsi   String
  status      String     @default("menunggu")
  balasan     String?
  lampiran    String?    // URL foto dari Cloudinary (lampiran dari mahasiswa)
  lampiranBalasan String? // URL foto lampiran dari admin (bukti tindak lanjut / penyelesaian)
  diteruskan   Boolean    @default(false) // true jika sudah diteruskan SUPER_ADMIN ke admin kategori
  diteruskanAt DateTime?  // waktu diteruskan
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  mahasiswaId String
  mahasiswa   Mahasiswa  @relation(fields: [mahasiswaId], references: [id])
}
