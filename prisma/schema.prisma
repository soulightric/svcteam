generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Mahasiswa {
  id        String     @id @default(cuid())
  nim       String     @unique
  nama      String
  password  String
  createdAt DateTime   @default(now())
  feedbacks Feedback[]
}

model Feedback {
  id          String     @id @default(cuid())
  kategori    String
  judul       String
  deskripsi   String
  status      String     @default("menunggu")
  balasan     String?
  lampiran    String?    // URL foto dari Cloudinary
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  mahasiswaId String
  mahasiswa   Mahasiswa  @relation(fields: [mahasiswaId], references: [id])
}
